# ─── Django Core ─────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=troque-por-chave-longa-e-aleatoria
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=servidor-qualificacao.tailbeb7d5.ts.net,100.76.30.36,localhost
CSRF_TRUSTED_ORIGINS=https://servidor-qualificacao.tailbeb7d5.ts.net:8443


# ─── Banco de Dados ──────────────────────────────────────────────────────────
# Em produção o app fala com o serviço "db" do docker-compose.yml
DB_ENGINE=django.db.backends.postgresql
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=troque-por-senha-segura
DB_HOST=db
DB_PORT=5432


# ─── Supabase (deixe vazio se não usar auth Supabase em prod) ────────────────
