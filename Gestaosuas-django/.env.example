# =============================================================================
# GESTAOSUAS-DJANGO — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# O arquivo .env NUNCA deve ser commitado no git.
# =============================================================================


# ─── Django Core ─────────────────────────────────────────────────────────────
# Gere uma chave segura com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-use-a-long-random-string

# 1 = modo desenvolvimento (runserver + debug toolbar)
# 0 = produção (gunicorn, sem debug)
DJANGO_DEBUG=1

# Hosts permitidos, separados por vírgula
# Dev: 127.0.0.1,localhost
# Prod: seu-dominio.com,www.seu-dominio.com
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Origens confiáveis para validação CSRF (necessário em produção com HTTPS)
# Prod: https://servidor-qualificacao.tailbeb7d5.ts.net:8443
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8001,http://localhost:8001


# ─── Banco de Dados (PostgreSQL) ─────────────────────────────────────────────
# Dev local: conecta ao Supabase Docker local (porta 54322)
# Dev Docker: usa host.docker.internal:54322 (configurado no docker-compose.dev.yml)
# Produção:   container "db" do docker-compose.yml na VPS
DB_ENGINE=django.db.backends.postgresql
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=54322


# ─── Supabase (opcional) ─────────────────────────────────────────────────────
# Se não configurado, o SupabaseAuthBackend fica desativado automaticamente
# e apenas o ModelBackend do Django é usado para autenticação.
#
# Dev local (Supabase CLI Docker):
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
#
# Produção (Supabase cloud — NÃO commitar estas chaves):
# SUPABASE_URL=https://<projeto>.supabase.co
# SUPABASE_ANON_KEY=<chave-anon-publica>
SUPABASE_URL=
SUPABASE_ANON_KEY=
